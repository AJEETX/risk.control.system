@using risk.control.system.Helpers;
@model CaseAgencyModel
@{
    var questionTime = @Model.CaseTask?.InvestigationReport?.AgentRemarksUpdated != null ?
    @Model.CaseTask.InvestigationReport.AgentRemarksUpdated.Value.ToString("dd-MMM-yy hh:mm tt") : null;
}

@if (!string.IsNullOrWhiteSpace(Model.CaseTask?.InvestigationReport?.AgentRemarks))
{
    <div class="col-12 col-md-6">
        <div class="card bg-light d-flex flex-fill border-success">
            <div class="card-header text-muted border-bottom-0">
                <h3 class="card-title">
                    <i class="far fa-comment"></i> Agent Remarks (@Model.CaseTask?.PolicyDetail?.InsuranceType?.GetEnumDisplayName())
                    <span class="hover-text">
                        <i class="fas fa-info-circle"></i>
                        <span class="tooltip-text" id="information">
                            <span>
                                <i class='far fa-hand-point-right'></i> Review <i class="far fa-comment"></i> Questionnaire (@Model.CaseTask?.PolicyDetail?.InsuranceType?.GetEnumDisplayName())
                            </span>
                        </span>
                    </span>
                </h3>
                <div class="card-tools">
                    <span data-bs-toggle="tooltip" title="Agent report time" class="badge badge-light"> <i class="nav-icon fas fa-clock"></i> @questionTime </span>
                </div>
            </div>
            <div class="progress">
                <i class="far fa-bookmark bookmark-green"></i>
                <div class="progress-bar progress-bar-green" role="progressbar">
                    Agent remarks (@Model.CaseTask?.PolicyDetail?.InsuranceType?.GetEnumDisplayName())
                </div>
            </div>
            <div class="card-footer text-muted border-bottom-0">
                <i class="fas fa-user-shield"></i>  Agent :<span class="badge badge-light">  @Model.CaseTask?.InvestigationReport.AgentEmail </span>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-12">
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead class="thead-light">
                                    <tr>
                                        <th class="w-50"> Agent Remarks</th>
                                        <th class="w-50">Edited Remarks</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="text-start">
                                            <div class="remark-container">
                                            @Model.CaseTask?.InvestigationReport?.AgentRemarks
                                            </div>
                                        </td>
                                        <td class="text-start">
                                            <div class="remark-container">
                                            @Model.CaseTask?.InvestigationReport?.AgentRemarksEdit
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
            </div>
            </div>
        </div>
        @* <partial name="_Chat" model="@Model" /> *@
    </div>
}