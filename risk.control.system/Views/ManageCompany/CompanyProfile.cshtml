@model risk.control.system.Models.ClientCompany

@{
    ViewData["Title"] = "Manage Company";
}

<section class="content">
    <input type="hidden" id="Isd" value="@Model?.Country.ISDCode" />
    <input type="hidden" id="countryCode" value="@Model?.Country.Code" />

    <div id="article">
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card shadow-lg border-0 h-100">
                    <div class="card-header bg-secondary text-white">
                        <h3 class="card-title m-0"><i class="fas fa-building me-2"></i> Company Profile</h3>
                    </div>
                    <div class="card-body p-4 text-center">
                        <div class="mb-4">
                            <span class="badge rounded-pill bg-light text-dark border shadow-sm p-2 px-3">
                                <i class="fas fa-clock text-primary me-1"></i>
                                Active Since: @Model.ActivatedDate?.ToString("dd-MMM-yyyy")
                            </span>
                        </div>

                        <div class="profile-img-container mb-3">
                            <img src="/Document/GetCompanyDocument/@Model.ClientCompanyId"
                                 class="rounded-circle img-thumbnail shadow-sm profile-img"
                                 alt="Company Profile" />
                        </div>

                        <h4 class="fw-bold mb-1">@Model.Name</h4>
                        <p class="text-muted small">@Model.Email</p>
                        
                        
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-lg border-0 h-100">
                    <div class="card-header bg-primary text-white">
                        <h3 class="card-title m-0"><i class="fas fa-wallet me-2"></i> Contact & Banking details</h3>
                    </div>
                    <div class="card-body p-3">
                        <div class="info-box shadow-none border mb-3">
                            <span class="info-box-icon bg-success"><i class="fas fa-phone"></i></span>
                            <div class="info-box-content">
                                <span class="info-box-text fw-bold">Mobile #</span>
                                <span class="info-box-number text-dark">+@Model.Country.ISDCode @Model.PhoneNumber</span>
                            </div>
                        </div>

                        <div class="info-box shadow-none border mb-3">
                            <span class="info-box-icon bg-info"><i class="fas fa-landmark"></i></span>
                            <div class="info-box-content">
                                <span class="info-box-text fw-bold">Bank Name</span>
                                <span class="info-box-number text-muted">@Model.BankName</span>
                            </div>
                        </div>

                        <div class="info-box shadow-none border mb-3">
                            <span class="info-box-icon bg-warning text-white"><i class="fas fa-code"></i></span>
                            <div class="info-box-content">
                                <span class="info-box-text fw-bold">IFSC Code</span>
                                <span class="info-box-number text-muted">@Model.IFSCCode</span>
                            </div>
                        </div>

                        <div class="info-box shadow-none border mb-0">
                            <span class="info-box-icon bg-dark text-white"><i class="fab fa-btc"></i></span>
                            <div class="info-box-content">
                                <span class="info-box-text fw-bold">Bank Account #</span>
                                <span class="info-box-number">@Model.BankAccountNumber</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-lg border-0 h-100">
                    <div class="card-header bg-success text-white">
                        <h3 class="card-title m-0"><i class="fas fa-map-marker-alt me-2"></i> Location</h3>
                    </div>
                    <div class="card-body p-3">
                        <div class="info-box shadow-none border mb-3">
                            <span class="info-box-icon bg-info"><i class="fas fa-map-pin"></i></span>
                            <div class="info-box-content">
                                <span class="info-box-text fw-bold">Street Address</span>
                                <span class="info-box-number text-muted">@Model.Addressline</span>
                            </div>
                        </div>

                        <div class="info-box shadow-none border mb-3">
                            <span class="info-box-icon bg-secondary"><i class="fas fa-city"></i></span>
                            <div class="info-box-content">
                                <span class="info-box-text fw-bold">District & State</span>
                                <span class="info-box-number text-muted">@Model.District.Name, @Model.State.Name</span>
                            </div>
                        </div>

                        <div class="info-box shadow-none border mb-3">
                            <span class="info-box-icon bg-dark text-white"><i class="fas fa-globe"></i></span>
                            <div class="info-box-content">
                                <span class="info-box-text fw-bold">Country</span>
                                <span class="info-box-number text-muted">@Model.Country.Name</span>
                            </div>
                        </div>

                        <div class="info-box shadow-none border mb-0">
                            <span class="info-box-icon bg-warning text-white"><i class="fas fa-mail-bulk"></i></span>
                            <div class="info-box-content">
                                <span class="info-box-text fw-bold">Pin Code</span>
                                <span class="info-box-number text-muted">@Model.PinCode.Name — @Model.PinCode.Code</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer">
            <div class="row float-right">
                <div class="col-md-12">
                    <div class="form-group">
                        <a id="edit-company" asp-controller="ManageCompany" asp-action="Edit" class="btn btn-warning"><i class='fas fa-building'></i> Edit Company</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="~/js/common/companies.js"></script>
}