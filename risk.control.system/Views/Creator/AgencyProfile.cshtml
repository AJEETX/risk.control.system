@model risk.control.system.Models.Vendor

@{
	ViewData["Title"] = @Applicationsettings.DETAILS;
}

<section class="content">
	<input type="hidden" id="vendorId" value="@Model.VendorId" />
	<input type="hidden" id="Isd" value="@Model?.Country!.ISDCode" />
	<input type="hidden" id="countryCode" value="@Model?.Country!.Code" />
	<div class="card shadow-lg border-1 rounded-lg">
		<div class="card-header bg-secondary text-white text-center">
			<h3 class="card-title"><i class="fas fa-building"></i>  Agency Profile</h3>
		</div>
		<div class="card-body">
			<div class="submit-progress hidden">
				<i class="fas fa-sync fa-spin fa-4x fa-fw"></i>
			</div>
			<div class="row">
				<div class="col-md-4 border-right">
					<div class="text-center">
						<div class="profile-img-container mb-3">
							<img src="/Document/GetAgencyDocument/@Model?.VendorId"
								 class="shadow-lg border profile-img img-fluid rounded-circle"
								 alt="User Profile" />
						</div>

						<h4 class="font-weight-bold">@Model.Name</h4>

						@if (Model.Status.ToString().Equals("ACTIVE", StringComparison.OrdinalIgnoreCase))
						{
							<div class="alert alert-success py-1 px-3 d-inline-block shadow-sm">
								<i class="fas fa-check-circle"></i> <strong>ACTIVE</strong>
							</div>
						}
						else
						{
							<span class="badge badge-secondary p-2">@Model.Status</span>
						}

						<p class="text-muted mt-2"><i class="fas fa-calendar-alt"></i> Active Since: @Model.ActivatedDate?.ToString("dd-MMM-yyyy")</p>

						<hr />
						<p class="text-muted text-sm">
							<i class="fa fa-star"></i>  <b>Rating: </b>
						</p>
						<ul class="ml-4 mb-0 fa-ul text-muted">
							<li class="small">
								<div id="agency-rating">
									<img src="/img/StarFade.gif" class="rating" id="1" alt="star" />
									<img src="/img/StarFade.gif" class="rating" id="2" alt="star" />
									<img src="/img/StarFade.gif" class="rating" id="3" alt="star" />
									<img src="/img/StarFade.gif" class="rating" id="4" alt="star" />
									<img src="/img/StarFade.gif" class="rating" id="5" alt="star" />
									<span id="rating-result">
										<span class="badge badge-light">(@Model.RateCount)</span>
										@if (Model.RateCount != null && Model.RateCount > 0)
										{
											decimal a = @Model.RateTotal.Value / @Model.RateCount.Value;
											<sup class="avr"> @a</sup>
										}
									</span>
									<div class="dropdown-divider"></div>
									<div id="rating-result-data" class="badge badge-light">
									</div>
								</div>
							</li>
						</ul>
						<div class="dropdown-divider"></div>
						<div class="card-footer">
							<div class="row">
								<div class="col-md-12">
									<div class="form-group">
										<label class="card-header shadow-lg rounded-lg text-sm bg-light" title="Agents (@Model.SelectedCountryId)" data-bs-toggle="tooltip"><i class="fa fa-user-secret"></i>  Agents (@Model.SelectedCountryId)</label>
										<label class="card-header shadow-lg rounded-lg text-sm bg-light" title="Service (@Model.VendorInvestigationServiceTypes!.Count)" data-bs-toggle="tooltip"><i class="fas fa-cogs"></i>  Service (@Model.VendorInvestigationServiceTypes.Count)</label>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
				<div class="col-md-8">
					<div class="row">
						<div class="col-md-6">
							<div class="small-box bg-light border">
								<div class="inner">
									<h3>@Model.SelectedDistrictId</h3>
									<p>Cases Completed</p>
								</div>
								<div class="icon"><i class="fas fa-check-double text-success"></i></div>
							</div>
							<div class="small-box bg-light border">
								<div class="inner">
									<h3>@Model.SelectedStateId</h3>
									<p>Current Cases</p>
								</div>
								<div class="icon"><i class="fas fa-hourglass-half text-info"></i></div>
							</div>

							<h5 class="text-primary border-bottom pb-2"><i class="fas fa-wallet mr-1"></i> Banking Details</h5>
							<div class="bg-light mb-4 p-3 rounded shadow-sm border">
								<div class="info-box">
									<span class="info-box-icon bg-info"><i class="fas fa-landmark"></i></span>
									<div class="info-box-content">
										<span class="info-box-text">Bank Name </span>
										<span class="info-box-number">@Model.BankName</span>
									</div>
								</div>

								<div class="info-box">
									<span class="info-box-icon bg-warning"><i class="fas fa-code"></i></span>
									<div class="info-box-content">
										<span class="info-box-text">IFSC Code</span>
										<span class="info-box-number">@Model.IFSCCode</span>
									</div>
								</div>

								<div class="info-box">
									<span class="info-box-icon bg-dark"><i class="fab fa-btc"></i></span>
									<div class="info-box-content">
										<span class="info-box-text">Bank Account #</span>
										<span class="info-box-number">@Model.BankAccountNumber</span>
									</div>
								</div>
							</div>
						</div>
						<div class="col-md-6">
							<h5 class="text-primary border-bottom pb-2"><i class="fas fa-map-marker-alt"></i> Domain & Address</h5>
							<div class="bg-light p-3 rounded shadow-sm border">
								<div class="info-box">
									<span class="info-box-icon bg-primary"><i class="fas fa-envelope"></i></span>
									<div class="info-box-content">
										<span class="info-box-text">Domain name</span>
										<span class="info-box-number"><span class="blue">@Model.Email</span></span>
									</div>
								</div>
								<div class="info-box">
									<span class="info-box-icon bg-info"><i class="fas fa-map-marker-alt"></i></span>
									<div class="info-box-content">
										<span class="info-box-text">Street Address</span>
										<span class="info-box-number">@Model.Addressline</span>
									</div>
								</div>

								<div class="info-box">
									<span class="info-box-icon bg-secondary"><i class="fas fa-city"></i></span>
									<div class="info-box-content">
										<span class="info-box-text">District</span>
										<span class="info-box-number">@Model.District!.Name</span>
									</div>
								</div>

								<div class="info-box">
									<span class="info-box-icon bg-danger"><i class="fas fa-flag"></i></span>
									<div class="info-box-content">
										<span class="info-box-text">State</span>
										<span class="info-box-number">@Model.State!.Name</span>
									</div>
								</div>

								<div class="info-box">
									<span class="info-box-icon bg-dark"><i class="fas fa-globe"></i></span>
									<div class="info-box-content">
										<span class="info-box-text">Country</span>
										<span class="info-box-number">@Model.Country!.Name</span>
									</div>
								</div>
								<div class="info-box">
									<span class="info-box-icon bg-warning"><i class="fas fa-map-pin"></i></span>
									<div class="info-box-content">
										<span class="info-box-text">Pin Code</span>
										<span class="info-box-number">@Model.PinCode!.Name - @Model.PinCode.Code</span>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="card-footer">
			<div class="row float-right">
				<div class="col-md-12">
					<div class="form-group">
						<a id="back" asp-controller="Creator" asp-action="EmpanelledVendors"
							   asp-route-id="@Model.SelectedPincodeId" asp-route-vendorId="@Model.VendorId"
							   class="btn btn-outline-secondary" data-bs-toggle="tooltip" title="Back to Empanelled Agencies">
							<i class="fas fa-arrow-left"></i>
							<span class="badge badge-light"> <i class="fas fa-tasks"></i> </span> Back
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
	<script src="~/js/creator/agency-detail.js"></script>
}