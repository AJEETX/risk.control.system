@model List<FormField>

<h2>User Registration / Data Entry</h2>
<hr />

<form asp-action="SubmitForm" method="post" enctype="multipart/form-data">
    
    @foreach (var field in Model)
    {
        <div class="mb-3">
            <label class="form-label font-weight-bold">
                @field.Label 
                @if (field.IsRequired) { <span class="text-danger">*</span> }
            </label>

            @if (field.FieldType == "text")
            {
                <input type="text" name="field_@field.Id" class="form-control" @(field.IsRequired ? "required" : "") />
            }
            else if (field.FieldType == "number")
            {
                <input type="number" name="field_@field.Id" class="form-control" @(field.IsRequired ? "required" : "") />
            }
            else if (field.FieldType == "date")
            {
                <input type="text" name="field_@field.Id" class="form-control jquery-datepicker" placeholder="dd-mm-yyyy" @(field.IsRequired ? "required" : "") />
            }
            else if (field.FieldType == "file")
            {
                <input type="file" name="field_@field.Id" class="form-control" @(field.IsRequired ? "required" : "") />
            }
            else if (field.FieldType == "dropdown")
            {
                <select name="field_@field.Id" class="form-control" @(field.IsRequired ? "required" : "")>
                    <option value="">-- Select Option --</option>
                    @if (!string.IsNullOrEmpty(field.DropdownOptions))
                    {
                        foreach (var option in field.DropdownOptions.Split(','))
                        {
                            <option value="@option.Trim()">@option.Trim()</option>
                        }
                    }
                </select>
            }
        </div>
    }

    <button type="submit" class="btn btn-primary">Submit Form</button>
</form>