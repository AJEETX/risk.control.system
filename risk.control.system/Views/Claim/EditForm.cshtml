@model EditSubmissionViewModel

<h2>Edit Submission (ID: @Model.SubmissionId)</h2>
<hr />

<form asp-action="EditForm" asp-route-id="@Model.SubmissionId" method="post" enctype="multipart/form-data">

    @foreach (var item in Model.Fields)
    {
        <div class="mb-3">
            <label class="form-label fw-bold">
                @item.Field.Label
                @if (item.Field.IsRequired)
                {
                    <span class="text-danger">*</span>
                }
            </label>

            @if (item.Field.FieldType == "text")
            {
                <input type="text" name="field_@item.Field.Id" value="@item.CurrentValue" class="form-control" @(item.Field.IsRequired && string.IsNullOrEmpty(item.CurrentValue) ? "required" : "") />
            }
            else if (item.Field.FieldType == "number")
            {
                <input type="number" name="field_@item.Field.Id" value="@item.CurrentValue" class="form-control" @(item.Field.IsRequired && string.IsNullOrEmpty(item.CurrentValue) ? "required" : "") />
            }
            else if (item.Field.FieldType == "date")
            {
                string formattedDate = "";
                if (!string.IsNullOrEmpty(item.CurrentValue) && DateTime.TryParse(item.CurrentValue, out DateTime d))
                {
                    formattedDate = d.ToString("dd-MM-yyyy");
                }

                <input type="text" name="field_@item.Field.Id" value="@formattedDate" class="form-control jquery-datepicker" placeholder="dd-mm-yyyy" @(item.Field.IsRequired && string.IsNullOrEmpty(item.CurrentValue) ? "required" : "") />
            }
            else if (item.Field.FieldType == "file")
            {
                <input type="file" name="field_@item.Field.Id" class="form-control mb-1" />
                @if (!string.IsNullOrEmpty(item.CurrentValue))
                {
                    <div class="small text-muted">
                        Current file: <a href="@item.CurrentValue" target="_blank" class="text-decoration-underline">View File</a>
                    </div>
                }
            }
            else if (item.Field.FieldType == "dropdown")
            {
                <select name="field_@item.Field.Id" class="form-control" @(item.Field.IsRequired && string.IsNullOrEmpty(item.CurrentValue) ? "required" : "")>
                    <option value="">-- Select Option --</option>
                    @if (!string.IsNullOrEmpty(item.Field.DropdownOptions))
                    {
                        foreach (var option in item.Field.DropdownOptions.Split(','))
                        {
                            var optClean = option.Trim();
                            <option value="@optClean" selected="@(optClean == item.CurrentValue)">@optClean</option>
                        }
                    }
                </select>
            }
        </div>
    }

    <div class="mt-4">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="ViewSubmissions" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>