@model FillFormViewModel
<section class="content">
    <div class="card shadow-lg border-1 rounded-lg">

        <div class="card-header bg-secondary text-white text-center">
            <h3 class="card-title"><i class="fas fa-cog"></i> Submit New @Model.FormType.ToString()</h3>
        </div>
        <div class="card-body">
            <div class="submit-progress hidden">
                <i class="fas fa-sync fa-spin fa-4x fa-fw"></i>
            </div>

<form asp-action="SubmitForm" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="FormType" />
    <!-- ================= TAB HEADERS ================= -->
    <ul class="nav nav-tabs mb-4" id="claimFormTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold text-primary" id="policy-tab" data-bs-toggle="tab" data-bs-target="#policy-pane" type="button" role="tab" aria-controls="policy-pane" aria-selected="true">
                <i class="bi bi-shield-shaded me-2"></i>1. Policy Details
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold text-success" id="nominee-tab" data-bs-toggle="tab" data-bs-target="#nominee-pane" type="button" role="tab" aria-controls="nominee-pane" aria-selected="false">
                <i class="bi bi-person-badge me-2"></i>2. Nominee Details
            </button>
        </li>
        <!-- Only display the Claims specific tab layout element if the form type is Claim -->
        @if (Model.FormType == FormType.Claim)
        {
            <li class="nav-item" role="presentation">
                <button class="nav-link fw-bold text-danger" id="claim-tab" data-bs-toggle="tab" data-bs-target="#claim-pane" type="button" role="tab">
                    <i class="bi bi-exclamation-octagon me-2"></i>3. Claim Details
                </button>
            </li>
        }
    </ul>

    <!-- ================= TAB PANES (CONTENT BOARDS) ================= -->
    <div class="tab-content border p-4 bg-white rounded shadow-sm" id="claimFormTabsContent">

        <!-- PANEL 1: POLICY DETAILS -->
        <div class="tab-pane fade show active" id="policy-pane" role="tabpanel" aria-labelledby="policy-tab" tabindex="0">
            <div class="row">
                @foreach (var field in Model.Fields.Where(f => f.Section == "Policy"))
                {
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">
                            @field.Label
                            @if (field.IsRequired)
                            {
                                <span class="text-danger">*</span>
                            }
                        </label>
                        <partial name="_DynamicFieldRender" model="field" />
                    </div>
                }
            </div>
        </div>

        <!-- PANEL 2: NOMINEE DETAILS -->
        <div class="tab-pane fade" id="nominee-pane" role="tabpanel" aria-labelledby="nominee-tab" tabindex="0">
            <div class="row">
                @foreach (var field in Model.Fields.Where(f => f.Section == "Nominee"))
                {
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">
                            @field.Label
                            @if (field.IsRequired)
                            {
                                <span class="text-danger">*</span>
                            }
                        </label>
                        <partial name="_DynamicFieldRender" model="field" />
                    </div>
                }
            </div>
        </div>
        @if (Model.FormType == FormType.Claim)
            {
                <!-- PANEL 3: CLAIM DETAILS -->
                <div class="tab-pane fade" id="claim-pane" role="tabpanel" aria-labelledby="claim-tab" tabindex="0">
                    <div class="row">
                        @foreach (var field in Model.Fields.Where(f => f.Section == "ClaimDetail"))
                        {
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">
                                    @field.Label
                                    @if (field.IsRequired)
                                    {
                                        <span class="text-danger">*</span>
                                    }
                                </label>
                                <partial name="_DynamicFieldRender" model="field" />
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

    <!-- Unified Form Action Buttons (Save and Cancel) -->
    <div class="row mt-4 pt-3 border-top">
        <div class="col-12 text-end">
            <a asp-action="ViewSubmissions" class="btn btn-outline-secondary px-4 py-2 me-2">Cancel</a>
            <button type="submit" class="btn btn-danger btn-lg px-5 shadow-sm">Save Changes</button>
        </div>
    </div>
</form>
</div>
</div>
</section>
                        
@section Scripts {
    <script src="/js/portal-admin/fill-form.js" asp-append-version="true"></script>
}