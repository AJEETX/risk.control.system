@{
    ViewData["Title"] = "Form Submitted Successfully";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6 text-center">
            
            <div class="card shadow border-0 p-5 rounded-4 bg-white">
                <div class="card-body">
                    
                    <div class="mb-4 d-inline-flex align-items-center justify-content-center bg-success text-white rounded-circle shadow p-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-check2-circle" viewBox="0 0 16 16">
                            <path d="M2.5 8a5.5 5.5 0 0 1 8.25-4.764.5.5 0 0 0 .5-.866A6.5 6.5 0 1 0 14.5 8a.5.5 0 0 0-1 0 5.5 5.5 0 1 1-11 0z"/>
                            <path d="M15.354 3.354a.5.5 0 0 0-.708-.708L8 9.293 5.354 6.646a.5.5 0 1 0-.708.708l3 3a.5.5 0 0 0 .708 0l7-7z"/>
                        </svg>
                    </div>
                    
                    <h1 class="display-6 text-success mb-3 fw-bold">Submission Received!</h1>
                    <p class="text-muted mb-4 lead">
                        Thank you for taking the time to fill out this form. Your response has been securely saved to our database.
                    </p>
                    
                    <hr class="my-4">
                    
                    <div class="d-grid gap-2 d-md-flex justify-content-center">
                        <a asp-action="FillForm" class="btn btn-primary px-4 py-2 btn-lg me-md-2">
                            Submit Another Response
                        </a>&nbsp;&nbsp;
                        <a href="ViewSubmissions" class="btn btn-outline-secondary px-4 py-2 btn-lg">
                            Go to Homepage
                        </a>
                    </div>
                </div>
            </div>
            
            <p class="text-muted mt-4 small">
                Submitted on @DateTime.Now.ToString("f")
            </p>
            
        </div>
    </div>
</div>