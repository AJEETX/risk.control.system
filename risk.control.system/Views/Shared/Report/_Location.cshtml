@using risk.control.system.Helpers;
@model ReportTemplate
<input type="hidden" id="latitude" />
<input type="hidden" id="longitude" />
<input type="hidden" name="caseId" value="@Model.CaseId" />
@foreach (var location in Model.LocationReport)
{
	location.SetStatus();
	var agent = location.AgentIdReport;
		location.Address = Model.InsuranceType == InsuranceType.CLAIM ? "Beneficiary" : location.Address;

	<div class="col-12 mb-4 location-container">
		<div class="card mb-2 border @location.StatusClass @location.LocationStatus">
			<div class="card-header bg-light text-white d-flex">
				<h5 class="mb-0 flex-grow-1 @location.LocationStatus">
					<i class="fas fa-map-marker-alt me-2"></i> @location.LocationName
					@if (location.IsRequired)
					{
						<span class="required-asterisk" title="Mandatory Location">*</span>
					}
				</h5>

				<button class="btn btn-sm @location.LocationStatusButton  mb-2" type="button"
						data-toggle="collapse"
						data-target="#location-@location.Id"
						aria-expanded="false"
						aria-controls="location-@location.Id">
					 <i class="fas fa-chevron-down"></i>
				</button>
			</div>
			

			<div id="location-@location.Id" class="collapse">

				<div class="card-body bg-light">
					@* Insert all the current content here (the agent table, face/doc/questions) *@

					@Html.AntiForgeryToken()
					<button class="btn btn-sm @location.AgentStatus mb-2" type="button"
							data-toggle="collapse"
							data-target="#agent-@location.Id"
							aria-expanded="false"
							aria-controls="agent-@location.Id">
						Agent ID <i class="fas fa-chevron-down"></i>
					</button>
					<div class="collapse" id="agent-@location.Id">
						<div class="table-responsive mb-4">
							<table class="table table-bordered table-hover dt-responsive nowrap w-100">
								<thead class="thead-light">
									<tr>
										<th class="col-verifier-name" title="Verifier Name">
											<img class="action-image" src="~/headers/customer.gif" />Agent ID
										</th>
										<th class="col-face-photo">
											<i class="far fa-user text-primary" title="This Image has Verifier photo at the location" data-bs-toggle="tooltip"></i> Agent Photo
										</th>
										<th class="col-address" title="Indicative Address Info">Indicative Address Info</th>
										<th class="col-weather" title="More Info">
											<img class="action-image" src="~/headers/information.gif" /> More Info
										</th>
										<th class="col-pin-img" title="Indicative Map Route">
											<img class="action-image" src="~/headers/pincode.gif" /> Indicative Map
										</th>
										<th class="col-match">Match</th>
									</tr>
								</thead>
								<tbody>
									<tr>
										<!-- Email or Report Type -->
										<td>
											<small>
											@if (agent!.ValidationExecuted)
											{
												@location.AgentEmail
											}
											else
											{
												@agent.ReportType.GetEnumDisplayName()
											}
											</small>
											@if (agent.IsRequired)
											{
												<span class="required-asterisk" title="Mandatory Location">*</span>
											}
										</td>

										<!-- ID Photo -->
										<td class="text-center face-photo-column">
											@if (agent.FaceResult != null && agent.FaceResult.TotalFacesDetected > 0)
											{
												<div class="badge bg-info text-white bottom-0 end-0 m-2 opacity-90">
													<i class="fas fa-user-check"></i> AI Verified
												</div>
											}
											@if (agent.ValidationExecuted)
											{
												<div class="position-relative d-inline-block mb-2 face-image-wrapper">
													<img id="face-img-@agent.Id"
														 src="/Document/GetAgentDocument/@agent.Id"
														 class="mobile-capture-info img-thumbnail img-fluid shadow-sm"
														 title="@location.AgentEmail photo" />
												</div>

												@if (agent.FaceResult != null)
												{
													<div class="text-start mt-1 p-2 bg-white rounded border face-metrics-box text-left">
														@if (agent.FaceResult.TotalFacesDetected == 0)
														{
															<div class="text-danger text-center fw-bold small">
																<i class="fas fa-exclamation-triangle"></i> No face detected
															</div>
														}
														else
														{
															@foreach (var face in agent.FaceResult.Faces)
															{
																<div class="card border-0 shadow-sm mb-3 @(face.FaceNumber > 1 ? "border-top pt-3" : "")">
																	<div class="card-body p-2">
																		<!-- Header -->
																		<span class="d-flex align-items-center text-primary fw-bold small mb-2">
																			<i class="fas fa-robot"></i>
																			<span class="badge fw-semibold small">
																				Face Detail #@face.FaceNumber
																			</span>
																		</span>

																		<!-- Metrics Table/Grid -->
																		<div class="d-flex flex-column gap-2 p-0 mb-2">
																			<!-- Age Range -->
																			<div class="p-2 rounded border d-flex align-items-center justify-content-between bg-light border-secondary-subtle">
																				<div class="d-flex align-items-center text-muted">
																					<i class="fas fa-hourglass-half fs-6 me-2"></i>
																					<span class="badge fw-semibold small">Age Range</span>
																				</div>
																				<span class="fw-bold small text-dark">@face.AgeRange</span>
																			</div>

																			<!-- Gender -->
																			<div class="p-2 rounded border d-flex align-items-center justify-content-between bg-light border-secondary-subtle">
																				<div class="d-flex align-items-center text-muted">
																					<i class="fas @(face.Gender?.ToLower() == "female" ? "fa-venus" : face.Gender?.ToLower() == "male" ? "fa-mars" : "fa-genderless") fs-6 me-2"></i>
																					<span class="badge fw-semibold small">Gender</span>
																				</div>
																				<div class="d-flex align-items-center gap-1">
																					<span class="fw-bold small text-dark">@face.Gender</span>
																					<span class="badge bg-white text-secondary border fw-normal text-xs">@face.GenderConfidence.ToString("F0")%</span>
																				</div>
																			</div>

																			<!-- Primary Emotion -->
																			<div class="p-2 rounded border d-flex align-items-center justify-content-between bg-light border-secondary-subtle">
																				<div class="d-flex align-items-center text-muted">
																					<i class="fas fa-heart fs-6 me-2"></i>
																					<span class="badge fw-semibold small">Emotion</span>
																				</div>
																				<span class="fw-bold small text-dark text-capitalize">@face.PrimaryEmotion</span>
																			</div>
																		</div>

																		<!-- Features Badges Grid -->
																		<div class="d-flex flex-column gap-2 pt-1 mt-2">
																			<!-- Smile -->
																			<div class="p-2 rounded border d-flex align-items-center justify-content-between @(face.IsSmiling ? "bg-success-subtle text-success border-success" : "bg-light text-muted border-secondary-subtle")">
																				<div class="d-flex align-items-center">
																					<i class="fas @(face.IsSmiling ? "fa-smile" : "fa-meh") fs-5 me-2"></i> <span class="badge  fw-semibold small"> Smile </span>
																				</div>
																				<span class="fs-5 fw-bold @(face.IsSmiling ? "text-success" : "text-danger")">
																					@(face.IsSmiling ? "✓" : "✗")
																				</span>
																			</div>

																			<!-- Glasses -->
																			<div class="p-2 rounded border d-flex align-items-center justify-content-between @(face.IsWearingGlasses ? "bg-info-subtle text-info-emphasis border-info" : "bg-light text-muted border-secondary-subtle")">
																				<div class="d-flex align-items-center">
																					<i class="fas fa-glasses fs-5 me-2"></i> <span class="badge fw-semibold small"> Glasses </span>

																				</div>
																				<span class="fs-5 fw-bold @(face.IsWearingGlasses ? "text-success" : "text-danger")">
																					@(face.IsWearingGlasses ? "✓" : "✗")
																				</span>
																			</div>

																			<!-- Beard -->
																			<div class="p-2 rounded border d-flex align-items-center justify-content-between @(face.HasBeard ? "bg-warning-subtle text-warning-emphasis border-success" : "bg-light text-muted border-secondary-subtle")">
																				<div class="d-flex align-items-center">
																					<i class="fas fa-user-tie fs-5 me-2"></i> <span class="badge fw-semibold small"> Beard </span>

																				</div>
																				<span class="fs-5 fw-bold @(face.HasBeard ? "text-success" : "text-danger")">
																					@(face.HasBeard ? "✓" : "✗")
																				</span>
																			</div>
																		</div>
																	</div>
																</div>
															}
														}

													</div>
												}
											}
											else
											{
												<img src="~/img/no-user.png" class="img-thumbnail img-fluid profile-image" />
											}
										</td>

										<!-- Address or fallback -->
										<td>
											@if (agent.ValidationExecuted)
											{
															<div>@agent.LongLat</div>
												<small>@agent.LocationAddress</small>
												<span class="badge badge-light">
														Indicative Distance from @location.Address Address  @agent.Distance
													</span>
											}
											else
											{
												<img src="~/img/no-map-image.jpeg" class="img-thumbnail img-fluid profile-image" />
											}
										</td>
										<td>
												<small>@agent.LocationInfo</small>

											</td>

										<!-- Map Image -->
										<td>
											@if (agent.ValidationExecuted && agent.LocationMapUrl != null)
											{
												<img src="@string.Format(@agent.LocationMapUrl, "500", "500")"
													 class="mobile-capture-info"
													 data-faceid="@agent.Id"
													 data-locationid="@location.Id"
													 data-caseid="@Model.CaseId"
													 data-source="agent"
													 title="Captured map route" />

											}
											else
											{
												<img src="~/img/no-map.jpeg" class="img-thumbnail img-fluid profile-image" />
											}
										</td>
										<!-- Match status -->
										<td>
											@if (agent.ValidationExecuted)
											{
												@if (agent.ImageValid.HasValue && agent.ImageValid.Value)
												{
													<i class="fa fa-check-circle text-success" title="Matched" data-bs-toggle="tooltip"></i>
												}
												else
												{
													<i class="fa fa-times-circle text-danger" title="Not matched" data-bs-toggle="tooltip"></i>
												}
											}
											else
											{
												<i class="fa fa-times-circle text-muted" title="Not validated" data-bs-toggle="tooltip"></i>
											}
											<span>@agent.Similarity</span>
										</td>
									</tr>
								</tbody>
							</table>
						</div>
					</div>
					<!-- FaceIds Table -->
					<partial name="Report/_LocationFaceId" model="@location" />

					<!-- DocumentIds Table -->

					<partial name="Report/_LocationDocId" model="@location" />

					<!-- Media Table -->
					<partial name="Report/_LocationMedia" model="@location" />
					<!-- Questions Table -->
					<partial name="Report/_LocationQuestion" model="@location" />
				</div> <!-- card-body -->
			</div> <!-- collapse -->
		</div> <!-- card -->
	</div> <!-- col-12 -->
}
<partial name="_ReportModal" />