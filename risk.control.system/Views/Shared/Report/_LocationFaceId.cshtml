@using risk.control.system.Helpers;
@model LocationReport
@{
	var location = Model;
}
@if (location.FaceIds?.Any(f => f.Selected) == true)
{  
	<div class="table-responsive mb-4">
		<table class="table table-bordered table-hover dt-responsive nowrap w-100">
			<thead class="thead-light">
				<tr>
					<th scope="col" class="min-vw-25" title="Person Info" data-toggle="tooltip">
						<img class="action-image me-2" src="~/headers/customer.gif" alt="Person Info" />Person Info
					</th>
					<th scope="col" class="text-center col-1" data-toggle="tooltip" title="Person Photo">
						<i class="far fa-user text-primary" title="Agent photo at location"></i> Person Photo
					</th>
					<th scope="col" class="w-25" data-toggle="tooltip" title="AI Analytics & Info">
						<img class="action-image me-2" src="~/headers/information.gif" alt="Info" />AI Analytics & Info
					</th>
					<th scope="col" class="min-vw-25" title="Address Info" data-toggle="tooltip"> <i class="fas fa-home"></i>  Address Info</th>

					<th scope="col" class="text-center col-1" data-toggle="tooltip" title="Map View">
						<img class="action-image me-2" src="~/headers/pincode.gif" alt="Map" />Map View
					</th>
					<th scope="col" class="text-center col-1" data-toggle="tooltip" title="Match">Match</th>
				</tr>
			</thead>

		<tbody>
			@foreach (var face in location.FaceIds.Where(f => f.Selected))
			{
					<tr class="align-middle">
						<td>
							<div class="text-start mt-1 p-2 bg-white rounded bordertext-left" data-toggle="tooltip" title="Person Type">
								@face.ReportName
								@if (face.IsRequired)
								{
									<span class="required-asterisk" title="Mandatory Location" data-toggle="tooltip">*</span>
								}
							</div>
							<div class="p-2 bg-white rounded border d-flex align-items-center justify-content-between shadow-sm" title="Captured Time" data-toggle="tooltip">
								<span class="badge bg-dark px-2.5 py-1.5 fs-7 fw-medium">
									<i class="fas fa-clock me-1 text-warning"></i>
									<span class="local-time-display" data-utc="@(face.LongLatTime.HasValue ? face.LongLatTime.Value.ToString("o") : "")">
										@(face.LongLatTime.HasValue ? "Loading..." : "--")
									</span>
								</span>
							</div>
						</td>
						<td class="text-center face-photo-column">
							@if (face.FaceResult != null && face.FaceResult.TotalFacesDetected > 0)
							{
								<div class="badge bg-info text-white bottom-0 end-0 m-2 opacity-90">
									<i class="fas fa-user-check"></i> AI Verified
								</div>
							}
							@if (face.ValidationExecuted)
							{
								<div class="position-relative d-inline-block mb-2">
									<img id="face-img-@face.Id"
										 src="/Document/GetFaceDocument/@face.Id"
										 class="mobile-capture-map  img-thumbnail thumbnail img-fluid shadow-sm preview-image"
										 title="@face.ReportName photo" />
								</div>

								
							}
							else
							{
								<img src="~/img/no-user.png" class="img-thumbnail img-fluid profile-image" />
							}
						</td>
						
						<td>
							@if (face.FaceResult != null)
							{
								<div class="text-start mt-1 p-2 bg-white rounded border text-left">
									@if (face.FaceResult.TotalFacesDetected == 0)
									{
										<div class="text-danger text-center fw-bold small">
											<i class="fas fa-exclamation-triangle"></i> No face detected
										</div>
									}
									else
									{
										@foreach (var faceData in face.FaceResult.Faces)
										{
											<div class="card border-0 shadow-sm mb-3 @(faceData.FaceNumber > 1 ? "border-top pt-3" : "")">
												<div class="card-body p-2">
													<!-- Metrics Table/Grid -->
													<div class="d-flex flex-column gap-2 p-0 mb-2">
														<!-- Age Range -->
														<div class="p-2 rounded border d-flex align-items-center justify-content-between bg-light border-secondary-subtle">
															<div class="d-flex align-items-center text-muted">
																<i class="fas fa-hourglass-half fs-6 me-2"></i>
																<span class="badge fw-semibold">Age Range</span>
															</div>
															<span class="fw-bold text-dark">@faceData.AgeRange</span>
														</div>

														<!-- Gender -->
														<div class="p-2 rounded border d-flex align-items-center justify-content-between bg-light border-secondary-subtle">
															<div class="d-flex align-items-center text-muted">
																<i class="fas @(faceData.Gender?.ToLower() == "female" ? "fa-venus" : faceData.Gender?.ToLower() == "male" ? "fa-mars" : "fa-genderless") fs-6 me-2"></i>
																<span class="badge fw-semibold ">Gender</span>
															</div>
															<div class="d-flex align-items-center gap-1">
																<span class="fw-bold text-dark">@faceData.Gender</span>
																<span class="badge bg-white text-secondary border fw-normal text-xs">@faceData.GenderConfidence.ToString("F0")%</span>
															</div>
														</div>

														<!-- Primary Emotion -->
														<div class="p-2 rounded border d-flex align-items-center justify-content-between bg-light border-secondary-subtle">
															<div class="d-flex align-items-center text-muted">
																<i class="fas fa-heart fs-6 me-2"></i>
																<span class="badge fw-semibold">Emotion</span>
															</div>
															<span class="fw-bold text-dark text-capitalize">@faceData.PrimaryEmotion</span>
														</div>
													</div>

													<!-- Features Badges Grid -->
													<div class="d-flex flex-column gap-2 pt-1 mt-2">
														<!-- Smile -->
														<div class="p-2 rounded border d-flex align-items-center justify-content-between @(faceData.IsSmiling ? "bg-success-subtle text-success border-success" : "bg-light text-muted border-secondary-subtle")">
															<div class="d-flex align-items-center">
																<i class="fas @(faceData.IsSmiling ? "fa-smile" : "fa-meh") fs-5 me-2"></i> <span class="badge  fw-semibold "> Smile </span>
															</div>
															<span class="fs-5 fw-bold @(faceData.IsSmiling ? "text-success" : "text-danger")">
																@(faceData.IsSmiling ? "✓" : "✗")
															</span>
														</div>

														<!-- Glasses -->
														<div class="p-2 rounded border d-flex align-items-center justify-content-between @(faceData.IsWearingGlasses ? "bg-info-subtle text-info-emphasis border-info" : "bg-light text-muted border-secondary-subtle")">
															<div class="d-flex align-items-center">
																<i class="fas fa-glasses fs-5 me-2"></i> <span class="badge fw-semibold "> Glasses </span>

															</div>
															<span class="fs-5 fw-bold @(faceData.IsWearingGlasses ? "text-success" : "text-danger")">
																@(faceData.IsWearingGlasses ? "✓" : "✗")
															</span>
														</div>

														<!-- Beard -->
														<div class="p-2 rounded border d-flex align-items-center justify-content-between @(faceData.HasBeard ? "bg-warning-subtle text-warning-emphasis border-success" : "bg-light text-muted border-secondary-subtle")">
															<div class="d-flex align-items-center">
																<i class="fas fa-user-tie fs-5 me-2"></i> <span class="badge fw-semibold "> Beard </span>

															</div>
															<span class="fs-5 fw-bold @(faceData.HasBeard ? "text-success" : "text-danger")">
																@(faceData.HasBeard ? "✓" : "✗")
															</span>
														</div>
													</div>
												</div>
											</div>
										}
									}

								</div>
							}
						</td>
						<td>
							<div class="d-flex flex-column gap-2 p-1">
								<div class="card border border-light-subtle shadow-sm bg-white rounded-3 overflow-hidden">
									<div class="card-header bg-light py-1 px-2 border-bottom border-light-subtle text-center">
										<small class="text-secondary fw-bold text-uppercase tracking-wider fs-8">
											<i class="fas fa-compass me-1 text-primary"></i> Latitude, Longitude
										</small>
									</div>
									<div class="card-body p-2 bg-white text-center">
										<code class="text-dark fw-bold small">@face.LongLat</code>
									</div>
								</div>

								<div class="card border border-light-subtle shadow-sm bg-white rounded-3 overflow-hidden">
									<div class="card-header bg-light py-1 px-2 border-bottom border-light-subtle text-center">
										<small class="text-secondary fw-bold text-uppercase tracking-wider fs-8" title="From Agent Address to @location.Address Address">
											<i class="fas fa-route me-1 text-warning"></i> Indicative Distance
										</small>
									</div>
									<div class="card-body p-2 bg-white text-center">
										<span class="badge bg-light text-dark border border-secondary-subtle fw-bold fs-7">
											@face.Distance
										</span>
									</div>
								</div>

								<div class="card border border-light-subtle shadow-sm bg-white rounded-3 overflow-hidden">
									<div class="card-header bg-light py-1 px-2 border-bottom border-light-subtle text-center">
										<small class="text-secondary fw-bold text-uppercase tracking-wider fs-8">
											<i class="fas fa-cloud-sun me-1 text-info"></i> Weather Info
										</small>
									</div>
									<div class="card-body p-2 bg-white">
										<div class="text-muted small italic">@face.LocationInfo</div>
									</div>
								</div>
							</div>
						</td>
						<td class="text-center">
							@if (face.ValidationExecuted && face.LocationMapUrl != null)
							{
								<img src="@string.Format(@face.LocationMapUrl, "300", "300")"
									 class="mobile-capture-map map-image"
									 data-faceid="@face.Id"
									 data-locationid="@location.Id"
									 data-source="face"
									 title="Click to view map" />
								<div class="d-flex flex-column gap-2 p-1">
									<div class="card border border-light-subtle shadow-sm bg-white rounded-3 overflow-hidden">
										<div class="card-header bg-light py-1 px-2 border-bottom border-light-subtle text-center">
											<small class="text-secondary fw-bold text-uppercase tracking-wider fs-8">
												<i class="fas fa-map-pin me-1 text-danger"></i> Captured Address
											</small>
										</div>
										<div class="card-body p-2 bg-white">
											<div class="text-dark fw-medium small text-wrap">@face	.LocationAddress</div>
										</div>
									</div>
								</div>

							}
							else
							{
								<img src="~/img/no-map.jpeg" class="thumbnail profile-image doc-profile-image" />
							}
						</td>
						<td class="text-center">
							<div class="d-flex flex-column align-items-center justify-content-center gap-1">
								@if (face.ValidationExecuted)
								{
									if (face.ImageValid.GetValueOrDefault())
									{
										<span class="badge bg-success-subtle text-success border border-success px-2 py-1 small">
											<i class="fas fa-check-circle me-1"></i> Valid
										</span>
									}
									else
									{
										<span class="badge bg-danger-subtle text-danger border border-danger px-2 py-1 small">
											<i class="fa fa-times-circle me-1"></i> Invalid
										</span>
									}
								}
								else
								{
									<span class="badge bg-secondary-subtle text-muted border px-2 py-1 small">
										<i class="fa fa-minus-circle me-1"></i> Pending
									</span>
								}
								<span class="fw-bold small text-secondary mt-1">@face.Similarity</span>
							</div>
						</td>
				</tr>
			}

		</tbody>
	</table>
	</div>
}
