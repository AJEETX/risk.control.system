@model ClientCompany
<a  class="brand-link">
    <div>
        @if (Model?.DocumentUrl is not null)
        {
            <img src="/Document/GetCompanyDocument/@Model.ClientCompanyId" alt="logo" class="brand-image elevation-2">
        }
        else
        {
            <img src="@Applicationsettings.NO_IMAGE" alt="logo" class="brand-image elevation-2">
        }
    </div>
    <div>
        @if (Model?.Name is not null)
        {
            var truncatedName = Model?.Name.Length > 15 ? Model?.Name.Substring(0, 15) + "..." : Model?.Name;
            <span class="brand-text font-weight-bold" title="@Model!.Name" data-bs-toggle="tooltip">@truncatedName </span>
        }
        else
        {
            <span class="brand-text font-weight-bold">add name.. </span>
        }
    </div>
</a>