@model risk.control.system.Models.Vendor

<div class="row">
	<input type="hidden" id="Isd" value="@Model?.Country?.ISDCode" />
	<input type="hidden" id="countryCode" value="@Model?.Country?.Code" />
	<div class="col-md-6">

		<div class="bg-light p-3 rounded mb-3 border">
			<i class="fas fa fa-globe mr-2"></i>Agency Domain: <span class="font-weight-bold blue">@Model?.Email</span>

			<input type="hidden" id="email" asp-for="Email" />

		</div>
		<div class="bg-light p-3 rounded mb-4 border">
			<h6 class="text-secondary border-bottom pb-2 mb-3">
				<i class="fas  fa-file-image-o mr-2"></i> Agency Logo
			</h6>
		<div class="form-group text-center">
			<div class="profile-img-container mb-2">
				<img id="createProfileImage" class="form-Image" src="/Document/GetAgencyDocument/@Model?.VendorId" title="Logo" alt="Logo" data-bs-toggle="tooltip" />
			</div>
			<div class="row justify-content-center">
				<div class="col-10 col-md-8">
			<div class="custom-file text-left">
				<input id="createImageInput" accept=".jpg,.jpeg,.png" asp-for="Document"
					   class="custom-file-input document-image-input d-none" type="file" data-bs-toggle="tooltip"
					   data-preview-id="createProfileImage" data-title-id="company-document" />

						<div class="row justify-content-center">
							<label for="createImageInput" class="btn btn-outline-primary">
								<i class="fa fa-cloud-upload mr-2"></i>
								Edit Logo
							</label>
						</div>
			</div>
			</div>
			</div>
			</div>
		</div>
		
		<div class="bg-light p-3 rounded mb-3 border">
			<h6 class="text-secondary border-bottom pb-2 mb-3">
				<i class="fas fa-id-card mr-2"></i> Name & Status
			</h6>
		<div class="form-group">
			<label class="input-group-label" for="Name"> Agency Name: </label>
			<div class="input-group mb-3">
				<div class="input-group-prepend">
					<span class="input-group-text"><i class="fas fa-building"></i> <i class="fa fa-asterisk asterik-style"></i></span>
				</div>
				<input type="text" id="Name" asp-for="Name" class="form-control remarks title-name" required placeholder="Enter Agency Name" maxlength="50" />
				<span asp-validation-for="Name" class="text-danger"></span>
			</div>
		</div>

		<div class="form-group">
			<label class="input-group-label" for="Status"> Status:</label>
			<div class="input-group mb-3">
				<div class="input-group-prepend">
					<span class="input-group-text">
						<i class="fa fa-toggle-on"></i>
						<i class="fa fa-asterisk asterik-style"></i>
					</span>
				</div>
        
				<select required id="Status" asp-for="Status" class="form-control remarks"
						asp-items="Html.GetEnumSelectList<VendorStatus>()"
						disabled="@(Model!.SelectedByCompany ? "disabled" : null)">
					<option value="">--- SELECT ---</option>
				</select>

				@if (Model.SelectedByCompany)
				{
					<input type="hidden" asp-for="Status" />
				}
        
				<span asp-validation-for="Status" class="text-danger"></span>
			</div>
		</div>
		</div>
		</div>
		<div class="col-md-6">
		<div class="bg-light p-3 rounded mb-3 border">
			<i class="fas  fa-lightbulb-o mr-2"></i><span>Active Since:</span> <span class="font-weight-bold"> @Model.ActivatedDate?.ToString("dd-MMM-yyyy")</span>
		</div>
		<div class="bg-light p-3 rounded mb-3 border">
			<h6 class="text-secondary border-bottom pb-2 mb-3">
				<i class="fas fa-bank mr-2"></i> Banking Details
			</h6>
			<div class="row">
				<div class="col-md-6">
					<div class="form-group">
						<label class="input-group-label" for="IFSCCode"> IFSC Code: </label>
						<div class="input-group mb-3 position-relative">
							<div class="input-group-prepend">
								<span class="input-group-text">
									<i class="fas fa-code"></i>
									<i class="fa fa-asterisk asterik-style"></i>
								</span>
							</div>
							<input type="text" id="IFSCCode" asp-for="IFSCCode" class="form-control remarks asterikx" required placeholder="IFSC Code" maxlength="11" data-bs-toggle="tooltip" />
							<span id="ifsc-spinner" class="text-secondary phone-icon d-none">
								<i class="fas fa-spinner fa-spin"></i>
							</span>
							<span id="ifsc-valid-icon" class="ifsc-valid-icon">
							</span>
							<span asp-validation-for="IFSCCode" class="text-danger"></span>
						</div>
					</div>
				</div>
				<div class="col-md-6">
					<div class="form-group">
						<label class="input-group-label" for="BankAccountNumber"> Bank Account #: </label>
						<div class="input-group mb-3">
							<div class="input-group-prepend">
								<span class="input-group-text"><i class="fab fa-btc"></i> <i class="fa fa-asterisk asterik-style"></i></span>
							</div>
							<input type="text" id="BankAccountNumber" asp-for="BankAccountNumber" class="form-control remarks" required placeholder="Bank Account #" maxlength="20" />
							<span asp-validation-for="BankAccountNumber" class="text-danger"></span>
						</div>
					</div>
				</div>
			</div>
			<div class="form-group">
				<label class="input-group-label" for="BankName"> Bank Name: </label>
				<div class="input-group mb-3">
					<div class="input-group-prepend">
						<span class="input-group-text">
							<i class="fas fa-landmark"></i>
							<i class="fa fa-asterisk asterik-style"></i>
						</span>
					</div>
					<input type="text" id="BankName" asp-for="BankName" class="form-control remarks title-name" required placeholder="..." maxlength="50" readonly tabindex="-1" title="Auto-selected" data-bs-toggle="tooltip" />
					<span asp-validation-for="BankName" class="text-danger"></span>
				</div>
			</div>
		</div>
		<div class="bg-light p-3 rounded mb-3 border">
			<h6 class="text-secondary border-bottom pb-2 mb-3">
				<i class="fas fa-map-marker-alt mr-2"></i> Address Details
			</h6>
			<partial name="Vendor/_AgencyAddress" model="@Model" />

			<div class="form-group">
				<label class="input-group-label" for="Addressline">Street Address:</label>
				<div class="input-group mb-3">
					<div class="input-group-prepend">
					<span class="input-group-text"><i class="fas fa-map-marker-alt"></i> <i class="fa fa-asterisk asterik-style"></i></span>
					</div>
					<input type="text" id="Addressline" asp-for="Addressline" class="form-control remarks" placeholder="Street Address..." required maxlength="70" />
					<span asp-validation-for="Addressline" class="text-danger"></span>
				</div>
			</div>
			</div>

			
		</div>
	</div>