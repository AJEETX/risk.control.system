@model risk.control.system.Models.Vendor
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<input type="hidden" id="Isd" value="@Model?.Country.ISDCode" />
<input type="hidden" id="countryCode" value="@Model?.Country.Code" />
<fieldset id="details-fields" disabled>

	<div class="card-body pb-1">
		<div class="row">
			<div class="col-md-6">

				<div class="form-group text-center image-logo-container">
					<div class="profile-img-container mb-2">
						<img id="document-Image" class="form-Image" src="/img/add-logo.png" title="Logo" alt="Logo" data-bs-toggle="tooltip" />
					</div>

					<div class="control-label">Logo <i class="fa fa-asterisk asterik-style-logo"></i></div>
					<div class="row justify-content-center">
						<div class="col-10 col-md-8">
							<div class="custom-file text-left">
								<input id="createImageInput" accept=".jpg,.jpeg,.png" asp-for="Document"
									   class="custom-file-input document-image-input" type="file" data-bs-toggle="tooltip"
									   data-preview-id="createProfileImage" data-title-id="company-document" />

								<label class="custom-file-label text-sm remarks" for="createImageInput">Choose logo...</label>
							</div>
						</div>
					</div>
				</div>

				<div class="form-group">
					<label class="input-group-label" for="Name"> Agency Name: </label>
					<div class="input-group mb-3">
						<div class="input-group-prepend">
							<span class="input-group-text" asp-for="Name"><i class="fas fa-building"></i> <i class="fa fa-asterisk asterik-style"></i></span>
						</div>
						<input type="text" id="Name" asp-for="Name" class="form-control remarks title-name" required placeholder="Agency Name" maxlength="30" autocomplete="off" />
						<span asp-validation-for="Name" class="text-danger"></span>
					</div>
				</div>

				<div class="form-group">
					<label class="input-group-label" for="PhoneNumber"> Mobile #:</label>
					<div class="input-group">

						<div class="input-group-prepend">
							@{
								var imgPath = "/flags/" + @Model.Country.Code.ToLower() + ".png";
							}
							<span class="input-group-text country-code-text" data-bs-toggle="tooltip" title="Country Code :+@Model?.Country.ISDCode">
								<img src="@imgPath" class="flag-icon" data-bs-toggle="tooltip" alt="flag" />  +@Model?.Country.ISDCode<i class="fa fa-asterisk asterik-style"></i>
							</span>
						</div>
						<input id="PhoneNumber" type="text" asp-for="PhoneNumber" class="form-control remarks" required maxlength="10" placeholder="Enter mobile # without country-code" data-bs-toggle="tooltip" />
						<span id="phone-spinner" class="text-secondary phone-icon d-none">
							<i class="fas fa-spinner fa-spin"></i>
						</span>
						<span id="phone-valid" class="text-success phone-icon d-none">
						</span>
						<span id="phone-invalid" class="text-danger phone-icon d-none">
							<i class="fas fa-times-circle"></i>
						</span>
						<span asp-validation-for="PhoneNumber" class="text-danger"></span>
					</div>
				</div>

				<div class="form-group">
					<label class="input-group-label" for="IFSCCode"> IFSC Code: </label>
					<div class="input-group mb-3 position-relative">
						<div class="input-group-prepend">
							<span class="input-group-text">
								<i class="fas fa-code"></i>
								<i class="fa fa-asterisk asterik-style"></i>
							</span>
						</div>
						<input type="text" id="IFSCCode" asp-for="IFSCCode" class="form-control remarks asterikx" required placeholder="IFSC Code" maxlength="11" data-bs-toggle="tooltip" />
						<span id="ifsc-spinner" class="text-secondary phone-icon d-none">
							<i class="fas fa-spinner fa-spin"></i>
						</span>
						<span id="ifsc-valid-icon" class="ifsc-valid-icon">
						</span>
						<span asp-validation-for="IFSCCode" class="text-danger"></span>
					</div>
				</div>
			</div>
			<div class="col-md-6">

				<div class="form-group">
					<label class="input-group-label" for="BankName"> Bank Name: </label>
					<div class="input-group mb-3">
						<div class="input-group-prepend">
							<span class="input-group-text">
								<i class="fas fa-landmark"></i>
								<i class="fa fa-asterisk asterik-style"></i>
							</span>
						</div>
						<input type="text" id="BankName" asp-for="BankName" class="form-control remarks title-name" required placeholder="..." maxlength="50" readonly tabindex="-1" title="Auto-selected" data-bs-toggle="tooltip" />
						<span asp-validation-for="BankName" class="text-danger"></span>
					</div>
				</div>

				<div class="form-group">
					<label class="input-group-label" for="BankAccountNumber"> Bank Account #: </label>
					<div class="input-group mb-3">
						<div class="input-group-prepend">
							<span class="input-group-text"><i class="fab fa-btc"></i> <i class="fa fa-asterisk asterik-style"></i></span>
						</div>
						<input type="text" id="BankAccountNumber" asp-for="BankAccountNumber" class="form-control remarks" required placeholder="Bank Account #" maxlength="20" />
						<span asp-validation-for="BankAccountNumber" class="text-danger"></span>
					</div>
				</div>
				<partial name="Vendor/_AgencyAddress" model="@Model" />

				<div class="form-group">
					<label class="input-group-label" for="Addressline"> Address: </label>
					<div class="input-group mb-3">
						<div class="input-group-prepend">
							<span class="input-group-text"><i class="fas fa-home"></i> <i class="fa fa-asterisk asterik-style"></i></span>
						</div>
						<input type="text" id="Addressline" asp-for="Addressline" class="form-control remarks" placeholder="Street Address..." required maxlength="70" />
						<span asp-validation-for="Addressline" class="text-danger"></span>
					</div>
				</div>
				@* <div class="form-group">
                <span class="input-group-label"> Remarks:</span>
                <div class="input-group mb-3">
                    <div class="input-group-prepend">
                        <span class="input-group-text" ><i class="fas fa-pencil-alt"></i>  <i class="fa fa-asterisk asterik-style"></i></span>
                    </div>
                    <input type="text" id="Description" asp-for="Description" class="form-control remarks" value="Add new Agency" placeholder="Remarks" required maxlength="50" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div> *@

				@*
            <div class="form-group">
                <span class="input-group-label"> Status:</span>
                <div class="input-group mb-3">
                    <div class="input-group-prepend">
                        <span class="input-group-text" for="Status"><i class="fa fa-toggle-on"></i> <i class="fa fa-asterisk asterik-style"></i></span>
                    </div>
                    <select required id="Status" asp-for="Status" class="form-control remarks" asp-items="Html.GetEnumSelectList<VendorStatus>()">
                        <option value="">--- SELECT ---</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>
            </div> *@
			</div>
		</div>
	</div>
</fieldset>
	<div class="card-footer">
		<div class="row">
			<div class="col-md-12">
				<div class="form-group text-right">
					@* <button id="reset" type="submit" onclick="clearAllInputs()" class="btn btn-outline-secondary">
                            <i class="fas fa-undo"></i> Reset
                            </button> *@
					<a id="cancel" asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary">
						<i class="fa fa-window-close"></i>
						@Applicationsettings.CANCEL
					</a>
					<button disabled id="create" type="submit" class="btn btn-success">
						<i class="fas fa-building"></i> Add Agency
					</button>
				</div>
			</div>
		</div>
	</div>
