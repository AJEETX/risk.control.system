@model risk.control.system.Models.ApplicationUser

<input asp-for="SelectedCountryId" type="hidden" id="SelectedCountryId" value="@Model?.CountryId" />
<input type="hidden" id="CountryId" value="@Model?.CountryId" />

<div class="form-group mb-2">
    <label class="input-group-label" for="PinCodeText">Pincode:</label>
    <div class="input-group autocomplete-wrapper">
        <div class="input-group-prepend">
            <span class="input-group-text">
                <i class="fas fa-map-pin"></i> <i class="fa fa-asterisk asterik-style"></i>
            </span>
        </div>
        <input type="text" id="PinCodeText" class="form-control remarks auto-dropdown" required placeholder="Type pincode or name" autocomplete="off" />
        <div id="pincode-loading" class="loading-spinner">
            <i class="fas fa-spinner fa-spin"></i>
        </div>
    </div>
    <span asp-validation-for="PinCodeId" class="text-danger small"></span>
    <input asp-for="SelectedPincodeId" type="hidden" id="SelectedPincodeId" value="@Model?.PinCodeId" />
    <input type="hidden" asp-for="PinCodeId" id="PinCodeId" />
</div>

<div class="row">
    <div class="col-md-6">
        <div class="form-group mb-2">
            <label class="input-group-label" for="StateText">State:</label>
            <div class="input-group autocomplete-wrapper">
                @{
                    var img = "/flags/" + @Model.Country.Code.ToLower() + ".png";
                }
                <div class="input-group-prepend">
                    <span class="input-group-text country-code-text" title="Country: @Model?.Country.Name">
                        <img src="@img" class="flag-icon" alt="flag" /> @Model?.Country.Code
                    </span>
                </div>
                <input readonly type="text" id="StateText" class="form-control bg-light-gray remarks" placeholder="..." tabindex="-1" />
                <div id="state-loading" class="loading-spinner">
                    <i class="fas fa-spinner fa-spin"></i>
                </div>
            </div>
            <input asp-for="SelectedStateId" type="hidden" id="SelectedStateId" value="@Model?.StateId" />
            <input type="hidden" asp-for="StateId" id="StateId" />
        </div>
    </div>
    <div class="col-md-6">
        <div class="form-group mb-2">
            <label class="input-group-label" for="DistrictText">District:</label>
            <div class="input-group autocomplete-wrapper">
                <div class="input-group-prepend">
                    <span class="input-group-text"><i class="fas fa-city"></i>  <i class="fa fa-asterisk asterik-style-none"></i></span>
                </div>
                <input readonly type="text" id="DistrictText" class="form-control bg-light-gray remarks" placeholder="..." tabindex="-1" />
                <div id="district-loading" class="loading-spinner">
                    <i class="fas fa-spinner fa-spin"></i>
                </div>
            </div>
            <input asp-for="SelectedDistrictId" type="hidden" id="SelectedDistrictId" value="@Model?.DistrictId" />
            <input type="hidden" asp-for="DistrictId" id="DistrictId" />
        </div>
    </div>
</div>