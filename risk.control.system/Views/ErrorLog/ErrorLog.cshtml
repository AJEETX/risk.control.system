@model IEnumerable<LogFileViewModel>

<section class="content">
	<div class="card shadow-lg border-1 rounded-lg">
		<div class="card-header bg-secondary text-white">
			<h5 class="mb-0"><i class="fas fa-file-medical-alt me-2"></i> Error Logs</h5>
		</div>
		<div class="card-body">
			<div class="submit-progress hidden">
				<i class="fas fa-sync fa-spin fa-4x fa-fw"></i>
			</div>
			<div class="table-responsive">
				<table class="table table-hover mb-0">
					<thead class="table-light">
						<tr>
							<th>Date Created</th>
							<th>File Name</th>
							<th>Size</th>
							<th class="text-end">Actions</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var file in Model)
						{
							<tr>
								<td class="align-middle">@file.Date.ToString("yyyy-MM-dd HH:mm")</td>
								<td class="align-middle fw-bold text-primary">@file.FileName</td>
								<td class="align-middle">@file.SizeKB KB</td>
								<td class="text-end">
									<a asp-action="Download" asp-route-fileName="@file.FileName"
										   class="btn btn-outline-success btn-sm">
										<i class="fas fa-download me-1"></i> Download
									</a>
								</td>
							</tr>
						}
						@if (!Model.Any())
						{
							<tr>
								<td colspan="4" class="text-center py-4 text-muted">
									No log files found in the directory.
								</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</div>
	</div>
</section>