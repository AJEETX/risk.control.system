@model CaseAgencyAgentModel
@{
	string address = string.Empty;
	var country = string.Empty;
	var imgPath = "/flags/in.png";
	int currentAgeinYrs = 0;
	if (Model.ClaimsInvestigation != null)
	{
		address = @Model.Beneficiary != null ? @Model.Beneficiary?.Addressline + " " +
		@Model.Beneficiary?.District?.Name + " " + @Model.Beneficiary?.State?.Name + " " + @Model.Beneficiary?.PinCode?.Code : string.Empty;
		
		if (Model.Beneficiary?.DateOfBirth != null)
		{
			var age = DateTime.UtcNow.Subtract(Model.Beneficiary.DateOfBirth.GetValueOrDefault()).TotalDays;
			currentAgeinYrs = (int)age / 365;
		}
	}
	country = @Model.Beneficiary?.Country?.Name;
	imgPath = "/flags/" + @Model.Beneficiary?.Country?.Code.ToLower() + ".png";
	var map = string.Format(Model.Beneficiary?.BeneficiaryLocationMap!, "400", "400");
	var beneficiarySMSCount = Model.ClaimsInvestigation?.CaseMessages!.Where(x => !x.IsCustomer).Count();
}
<div class="col-12 col-sm-6 d-flex align-items-stretch flex-column">
	<div class="card bg-light d-flex flex-fill">
		<div class="card-header text-muted border-bottom-0">
			<i class="fas fa-user-tie"></i>  Beneficiary Details
			<span class="hover-text">
				<i class="fas fa-info-circle"></i>
				<span class="tooltip-text" id="beneficiary-information">
					<li>
						<i class='fas fa-user-tie'></i> Beneficiary details
					</li>
					<li>
						<i class='far fa-hand-point-right'></i>
						<div class="btn btn-xs bg-teal">
							<i class="fas fa-comments"></i>
						</div> Send SMS to Beneficiary
					</li>
					<li>
						<i class='far fa-hand-point-right'></i>
						<div class="btn btn-xs btn-success">
							<i class="fas fa-user-tie"></i> ...
						</div> Show Beneficiary Details
					</li>
				</span>
			</span>
		</div>
		<div class="progress">
			<i class="far fa-bookmark bookmark-green"></i>
			<div class="progress-bar progress-bar-green" role="progressbar">
				<i class="fas fa-user-tie"></i>
			</div>
		</div>
		<div class="card-body">
			<div class="row">
				<div class="col-7">
					<h2 class="lead"><b>@Model?.Beneficiary!.Name</b></h2>
					<p class="text-muted text-sm">
						Relation: <b> @Model?.Beneficiary?.BeneficiaryRelation!.Name</b>
					</p>
					<ul class="ml-4 mb-0 fa-ul text-muted">
						<li class="small">
							<span class="fa-li">
								<i class="fas fa-user-alt"></i>
							</span>
							Age:<b> @currentAgeinYrs</b>
						</li>

						<li class="small">
							<span class="fa-li">
								<i class="fa fa-money"></i>
							</span>
							Annual Income:(@Model?.Currency) <b> @Model?.Beneficiary?.Income</b>
						</li>
						
						<li class="small">
							<span class="fa-li">
								<i class="fas fa-lg fa-building"></i>
							</span>
							Address:<b> @address</b>
						</li>
						<li class="small">
							<span class="fa-li">
								<i class="fas fa-lg fa-globe"></i>
							</span>
							Country:
							@if (!string.IsNullOrWhiteSpace(country))
							{
								<img src="@imgPath" class="flag-icon" data-bs-toggle="tooltip" />

								<b> @country</b>
							}
						</li>
						<li class="small margin-top-16">
							<span class="fa-li">
								<i class="fas fa-lg fa-phone"></i>
							</span>
							Mobile #: + <b>@Model?.Beneficiary?.Country?.ISDCode  @Model?.Beneficiary?.PhoneNumber</b>
							@if (Model?.Beneficiary?.IsValidPhoneNumber == true)
							{
								<i class="fas fa-check-circle text-success" title="Valid Mobile Number" data-bs-toggle="tooltip"></i>
							}
							else
							{
								<i class="fas fa-times-circle text-danger" title="Invalid Mobile Number" data-bs-toggle="tooltip"></i>
							}
						</li>
					</ul>
				</div>
				<div class="col-5 text-center">
					<p class="text-muted text-sm">
						@if (Model?.Beneficiary?.ImagePath is not null)
						{
							<img id="bImage" class="img-fluid block-data" src="/Document/GetBeneficiaryDocument/@Model?.Beneficiary?.BeneficiaryDetailId" data-bs-toggle="tooltip" title="Beneficiary Photo" />
						}
						else
						{
							<img id="bImage" class="img-fluid block-data" src="@Applicationsettings.NO_USER" data-bs-toggle="tooltip" title="No Beneficiary Photo" />
						}
					</p>
					<p class="text-muted text-sm">
						<img id="beneficiaryGoogleMap" class="img-fluid block-data" src="@map" data-bs-toggle="tooltip" title="Display Beneficiary Address in map" />
					</p>
				</div>
			</div>
		</div>

		<div class="card-footer">
			<div class="text-right">
				<button id="beneficiary-comments" class="btn btn-sm bg-teal" title="Send Sms to Beneficiary" data-bs-toggle="tooltip">
					<i class="fas fa-comments"></i>
					<span id="beneficiary-sms-count" class="badge bg-danger ms-1">@beneficiarySMSCount</span>
				</button>
				<button id="beneficiary-detail" class="btn btn-sm btn-success" title="Display Beneficiary Detail" data-bs-toggle="tooltip">
					<i class="fas fa-user-tie"></i> ...
				</button>
			</div>
		</div>
	</div>
</div>