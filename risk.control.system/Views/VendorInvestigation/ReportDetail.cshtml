@model CaseAgencyModel

@{
	ViewData["Title"] = "Case: Report ";
}

<section class="content">
	<div id="article" class="shadow-lg border-1 rounded-lg">
		<div class="card-header bg-secondary text-white text-center">
			<h3 class="card-title">
				<i class="far fa-file-alt"></i> Submit
				<span class="hover-text">
					<i class="fas fa-info-circle"></i>
					<span class="tooltip-text" id="information">
						<li>
							<i class='far fa-hand-point-right'></i> Verify <i class='fas fa-check-circle'></i> Report
						</li>
						<li>
							<i class='far fa-hand-point-right'></i> Review <i class="far fa-comment"></i> remarks
						</li>
						<li>
							<i class='far fa-hand-point-right'></i> Add <i class='fas fa-check-circle'></i> remark
						</li>
						<li>
							<i class='far fa-hand-point-right'></i> Check T&C <input type="checkbox"> checkbox
						</li>
						<li>
							<i class='far fa-thumbs-down'></i> <button class='badge badge-danger btn-lg'><i class='fas fa-sync'></i> <b>Re-allocate</b> </button>
						</li>
						<li>
							<i class='far fa-thumbs-up'></i> <button class='badge badge-success btn-lg'><i class='far fa-file-alt'></i> <b>SUBMIT</b> </button>  to <b>@Model.CaseTask?.ClientCompany?.Email</b>
						</li>
						
					</span>
				</span>
			</h3>
		</div>

		<div class="card shadow-lg border-1 rounded-lg direct-chat-warning collapsed-card">
			<div class="card-header bg-light text-white text-center">
				<h3 class="card-title">
					Case: <span class="badge badge-light">
					<i class="far fa-file-powerpoint"></i>  @Model.CaseTask?.PolicyDetail?.ContractNumber
				</span>
				<span class="hover-text">
					<i class="fas fa-info-circle"></i>
					<span class="tooltip-text" id="information">
						<li>

							<i class='far fa-file-powerpoint'></i> Case details
						</li>
						@if (Model.CaseTask?.PolicyDetail?.InsuranceType == InsuranceType.UNDERWRITING)
						{
							<li>
								<i class='fa fa-user-plus'></i> Customer details
							</li>
						}
						else
						{
							<li> <i class='fas fa-user-tie'></i> Beneficiary details </li>
						}
					</span>
				</span>
			</h3>
			<div class="card-tools">
				<span data-bs-toggle="tooltip" title="Case # : @Model.CaseTask?.PolicyDetail?.ContractNumber" class="badge badge-light">
					<b><i class='far fa-hand-point-right'></i></b>
				</span>
				<button type="button" class="btn btn-tool" data-card-widget="collapse">
					<i class="fas fa-plus"></i>
				</button>
			</div>
		</div>

		<div class="card-body pb-0">

			<div class="row">
				@{
					var pmodel = new CaseAgencyAgentModel
					{
						ClaimsInvestigation = Model.CaseTask!,
						Beneficiary = Model.Beneficiary!
					};

					<partial name="_CaseDetails" model="@pmodel" />
					@if (Model.CaseTask!.PolicyDetail!.InsuranceType == InsuranceType.UNDERWRITING)
					{
						<partial name="_CustomerDetails" model="@pmodel" />
					}
					else
					{
						<partial name="_BeneficiaryDetails" model="@pmodel" />
					}
				}
			</div>
		</div>
	</div>

		<form id="supervisor-form" method="post" asp-action="ProcessReport" asp-controller="AgencyReport" enctype="multipart/form-data">
			<input type="hidden" id="claimId" name="claimId" value="@Model.CaseTask?.Id" />
			<input type="hidden" id="policyDetailId" value="@Model.CaseTask?.PolicyDetail?.PolicyDetailId" />
			<input type="hidden" id="customerDetailId" value="@Model.CaseTask?.CustomerDetail?.CustomerDetailId" />
			<input type="hidden" id="beneficiaryId" value="@Model.Beneficiary?.BeneficiaryDetailId" />
			<partial name="_AgentReport" model="@Model" />
			<partial name="_Submit" model="@Model" />
		</form>
	</div>
</section>
@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
	<script src="~/js/common/case-details.js"></script>
	<script src="~/js/case-map.js"></script>
	<script src="~/js/supervisor/get-investigate-report.js"></script>
}