@model CaseAgencyAgentModel

@{
	ViewData["Title"] = "Details";
}
<section class="content">
	<input type="hidden" id="customerDetailId" value="@Model.ClaimsInvestigation?.CustomerDetail?.CustomerDetailId" />
	<input type="hidden" id="claimId" name="claimId" value="@Model.ClaimsInvestigation?.Id" />
	<input type="hidden" id="policyDetailId" value="@Model.ClaimsInvestigation?.PolicyDetail?.PolicyDetailId" />
	<input type="hidden" id="beneficiaryId" value="@Model.Beneficiary?.BeneficiaryDetailId" />
	<div id="article" class="shadow-lg border-1 rounded-lg">
		<div class="card-header bg-secondary text-white text-center">
			<h3 class="card-title">
				<i class="fas fa-newspaper"></i> Details
				<span class="hover-text">
					<i class="fas fa-info-circle"></i>
					<span class="tooltip-text" id="information">
						<li>

							<i class='far fa-file-powerpoint'></i> Case details.
						</li>
						@if (Model.ClaimsInvestigation?.PolicyDetail?.InsuranceType == InsuranceType.UNDERWRITING)
						{
							<li>
								<i class='fa fa-user-plus'></i> Customer details
							</li>
						}
						else
						{
							<li> <i class='fas fa-user-tie'></i> Beneficiary details </li>
						}
						@if (Model.Withdrawable)
						{
							<li>
								<button class='btn btn-danger btn-xs'>
									<span class='badge badge-danger btn-xs'>
										<i class='fas fa-undo'></i>
									</span> <b>Withdraw</b>
								</button>
							</li>
						}
						else
						{
							<li>
								<button id="back" disabled class="btn btn-outline-danger btn-xs">
									<span class="badge badge-light"> <i class="fas fa-undo"></i> </span> Withdraw
									<span class="badge badge-danger"><i class="fas fa-info"></i></span>
								</button>
							</li>
						}
					</span>
				</span>
			</h3>
		</div>
	</div>

	<div class="card shadow-lg border-1 rounded-lg direct-chat-warning expanding-card">
		<div class="card-header bg-light text-white text-center">
			<h3 class="card-title">
				<span class="badge badge-info" data-bs-toggle="tooltip" title="Status : @Model.ClaimsInvestigation?.SubStatus">
					<b>@Model.ClaimsInvestigation?.SubStatus</b>
				</span>
				<b><i class='far fa-hand-point-right'></i></b>

				<span class="badge badge-info" data-bs-toggle="tooltip"
					  title="Owner : @Model.ClaimsInvestigation?.CaseOwner">
					<b>
						@Model.ClaimsInvestigation?.CaseOwner
					</b>
				</span>
			</h3>
		</div>
		<div class="card-body">
			<div class="submit-progress hidden">
				<i class="fas fa-sync fa-spin fa-4x fa-fw"></i>
			</div>
			<div class="row">
				@{
					<input type="hidden" id="customerDetailId" value="@Model.ClaimsInvestigation?.CustomerDetail?.CustomerDetailId" />
					<input type="hidden" id="claimId" name="claimId" value="@Model.ClaimsInvestigation?.Id" />
					<input type="hidden" id="beneficiaryId" value="@Model.Beneficiary?.BeneficiaryDetailId" />
					<input type="hidden" id="policyDetailId" value="@Model.ClaimsInvestigation?.PolicyDetail?.PolicyDetailId" />
					<partial name="_CaseDetails" model="@Model" />
					@if (Model.ClaimsInvestigation?.PolicyDetail!.InsuranceType == InsuranceType.UNDERWRITING)
					{
						<partial name="_CustomerDetails" model="@Model" />
					}
					else
					{
						<partial name="_BeneficiaryDetails" model="@Model" />
					}
				}
			</div>
		</div>
		<div class="card-footer">
			<form id="withdraw-form" method="post" asp-action="WithdrawCaseFromAgent" asp-controller="DeclineCase">
				<input type="hidden" name="caseId" asp-for="@Model.ClaimsInvestigation!.Id" />
				<input type="hidden" name="policyNumber" asp-for="@Model.ClaimsInvestigation!.PolicyDetail!.ContractNumber" />
				<div class="row float-right">
					<div class="col-md-12">
						<a id="back" asp-action="Active" class="btn btn-sm btn-outline-secondary" data-bs-toggle="tooltip" title="Back to Active cases">
							<i class="fas fa-arrow-left"></i>
							<span class="badge badge-light"> <i class="fa fa-toggle-on"></i> </span> Back
						</a>
						@if(Model.Withdrawable)
							{
							<button id="submit-case" type="submit" class="btn btn-sm btn-danger"><i class="fas fa-undo"></i> Withdraw</button>
							}
							else
							{
							<span id="decline-information-popup" class="badge badge-light">
							<div class="btn btn-sm btn-outline-danger">
								<span class="badge badge-light"> <i class="fas fa-undo"></i> </span> Decline <span class="badge badge-danger">
								<i class="fas fa-info"></i>
							</span>
						</div>
					</span>
							}
							
				</div>
			</div>
		</form>
	</div>
</div>
</section>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
	<script src="~/js/common/case-details.js"></script>
	<script src="~/js/supervisor/claims-details.js"></script>
}