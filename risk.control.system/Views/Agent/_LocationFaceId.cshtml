@using risk.control.system.Helpers;
@model LocationReport
@{
	var location = Model;
}
@if (location.FaceIds?.Any(f => f.Selected) == true)
{
	<div class="table-responsive mb-4">

	<table class="table table-bordered table-hover dt-responsive nowrap w-100">
		<thead class="table-light">
			<tr>
				<th title="Verifier Name"><img class="action-image" src="~/headers/customer.gif" /></th>
				<th>
					<i class="far fa-user text-primary" title="This Image has Verifier photo at the location" data-toggle="tooltip"></i>
				</th>
				<th title="Verified Address"><img class="action-image" src="~/headers/pincode.gif" /></th>
				<th>Verified Address</th>
				<th title="More info"><img class="action-image" src="~/headers/information.gif" /></th>
				<th>Match</th>
				<th title="Action"><img class="action-image" src="~/headers/action.gif" /></th>
			</tr>
		</thead>
		<tbody>
			@foreach (var face in location.FaceIds.Where(f => f.Selected))
			{
				<tr>
					<td>
						@face.ReportName
						@if (face.IsRequired)
						{
							<span class="required-asterisk" title="Mandatory Location">*</span>
						}
					</td>
						<td class="text-center face-photo-column">
							@if (face.FaceResult != null && face.FaceResult.TotalFacesDetected > 0)
							{
								<div class="badge bg-info text-white bottom-0 end-0 m-2 opacity-90">
									<i class="fas fa-user-check"></i> AI Verified
								</div>
							}
							@if (face.ValidationExecuted)
							{
								<div class="position-relative d-inline-block mb-2 face-image-wrapper">
									<img id="face-img-@face.Id"
										 src="/Document/GetFaceDocument/@face.Id"
										 class="mobile-capture-info img-thumbnail img-fluid shadow-sm"
										 title="@location.AgentEmail photo" />
								</div>

								@if (face.FaceResult != null)
								{
									<div class="text-start mt-1 p-2 bg-white rounded border face-metrics-box text-left">
										@if (face.FaceResult.TotalFacesDetected == 0)
										{
											<div class="text-danger text-center fw-bold small">
												<i class="fas fa-exclamation-triangle"></i> No face detected
											</div>
										}
										else
										{
											@foreach (var faceData in face.FaceResult.Faces)
											{
												<div class="card border-0 shadow-sm mb-3 @(faceData.FaceNumber > 1 ? "border-top pt-3" : "")">
													<div class="card-body p-2">
														<!-- Header -->
														<span class="d-flex align-items-center text-primary fw-bold small mb-2">
															<i class="fas fa-robot"></i>
															<span class="badge fw-semibold small">
																Face Detail #@faceData.FaceNumber
															</span>
														</span>

														<!-- Metrics Table/Grid -->
														<div class="d-flex flex-column gap-2 p-0 mb-2">
															<!-- Age Range -->
															<div class="p-2 rounded border d-flex align-items-center justify-content-between bg-light border-secondary-subtle">
																<div class="d-flex align-items-center text-muted">
																	<i class="fas fa-hourglass-half fs-6 me-2"></i>
																	<span class="badge fw-semibold small">Age Range</span>
																</div>
																<span class="fw-bold small text-dark">@faceData.AgeRange</span>
															</div>

															<!-- Gender -->
															<div class="p-2 rounded border d-flex align-items-center justify-content-between bg-light border-secondary-subtle">
																<div class="d-flex align-items-center text-muted">
																	<i class="fas @(faceData.Gender?.ToLower() == "female" ? "fa-venus" : faceData.Gender?.ToLower() == "male" ? "fa-mars" : "fa-genderless") fs-6 me-2"></i>
																	<span class="badge fw-semibold small">Gender</span>
																</div>
																<div class="d-flex align-items-center gap-1">
																	<span class="fw-bold small text-dark">@faceData.Gender</span>
																	<span class="badge bg-white text-secondary border fw-normal text-xs">@faceData.GenderConfidence.ToString("F0")%</span>
																</div>
															</div>

															<!-- Primary Emotion -->
															<div class="p-2 rounded border d-flex align-items-center justify-content-between bg-light border-secondary-subtle">
																<div class="d-flex align-items-center text-muted">
																	<i class="fas fa-heart fs-6 me-2"></i>
																	<span class="badge fw-semibold small">Emotion</span>
																</div>
																<span class="fw-bold small text-dark text-capitalize">@faceData.PrimaryEmotion</span>
															</div>
														</div>

														<!-- Features Badges Grid -->
														<div class="d-flex flex-column gap-2 pt-1 mt-2">
															<!-- Smile -->
															<div class="p-2 rounded border d-flex align-items-center justify-content-between @(faceData.IsSmiling ? "bg-success-subtle text-success border-success" : "bg-light text-muted border-secondary-subtle")">
																<div class="d-flex align-items-center">
																	<i class="fas @(faceData.IsSmiling ? "fa-smile" : "fa-meh") fs-5 me-2"></i> <span class="badge  fw-semibold small"> Smile </span>
																</div>
																<span class="fs-5 fw-bold @(faceData.IsSmiling ? "text-success" : "text-danger")">
																	@(faceData.IsSmiling ? "✓" : "✗")
																</span>
															</div>

															<!-- Glasses -->
															<div class="p-2 rounded border d-flex align-items-center justify-content-between @(faceData.IsWearingGlasses ? "bg-info-subtle text-info-emphasis border-info" : "bg-light text-muted border-secondary-subtle")">
																<div class="d-flex align-items-center">
																	<i class="fas fa-glasses fs-5 me-2"></i> <span class="badge fw-semibold small"> Glasses </span>

																</div>
																<span class="fs-5 fw-bold @(faceData.IsWearingGlasses ? "text-success" : "text-danger")">
																	@(faceData.IsWearingGlasses ? "✓" : "✗")
																</span>
															</div>

															<!-- Beard -->
															<div class="p-2 rounded border d-flex align-items-center justify-content-between @(faceData.HasBeard ? "bg-warning-subtle text-warning-emphasis border-success" : "bg-light text-muted border-secondary-subtle")">
																<div class="d-flex align-items-center">
																	<i class="fas fa-user-tie fs-5 me-2"></i> <span class="badge fw-semibold small"> Beard </span>

																</div>
																<span class="fs-5 fw-bold @(faceData.HasBeard ? "text-success" : "text-danger")">
																	@(faceData.HasBeard ? "✓" : "✗")
																</span>
															</div>
														</div>
													</div>
												</div>
											}
										}

									</div>
								}
							}
							else
							{
								<img src="~/img/no-user.png" class="img-thumbnail img-fluid profile-image" />
							}
						</td>
					<td>
						@if (face.ValidationExecuted && face.LocationMapUrl != null)
						{
							<img src="@string.Format(@face.LocationMapUrl, "300","300")"
								 class="thumbnail-image thumbnail profile-image doc-profile-image map-image"
								 data-faceid="@face.Id"
								 data-locationid="@location.Id"
								 data-source="face"
								 title="Click to view map" />

						}
						else
						{
							<img src="~/img/no-map.jpeg" class="thumbnail profile-image doc-profile-image" />
						}
					</td>
					<td>
						@face.LocationAddress

					</td>
					<td>
						@face.LocationInfo

					</td>
					<td>
						@if (face.ValidationExecuted)
						{
							@if (face.ImageValid.GetValueOrDefault())
							{
								<i class='fas fa-check-circle i-green'></i>
							}
							else
							{
								<i class='fa fa-times i-orangered' aria-hidden='true'></i>
							}
						}
						else
						{
							<i class='fa fa-times i-grey' aria-hidden='true'></i>
						}
						@face.Similarity
					</td>
					<td>
						<input type="file" class="form-control remarks form-control-sm face-upload" data-faceid="@face.Id" accept="image/*" />
						<button type="button" class="btn btn-sm btn-success mt-2 upload-face-btn"
								data-faceid="@face.Id"
								data-locationid="@location.Id"
								data-location-name="@location.LocationName"
								data-name="@face.ReportName">
							<i class="fas fa-upload"></i> Upload
						</button>
						<div id="upload-status-@face.Id" class="text-success small mt-1"></div>
					</td>

				</tr>
			}

		</tbody>
	</table>

	</div>
}
