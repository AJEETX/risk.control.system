@using risk.control.system.Helpers;
@model LocationReport
<!-- Agent Table -->
@{
	var location = Model;
	var agent = location.AgentIdReport;
}

<div class="table-responsive mb-4">

<table class="table table-bordered table-hover dt-responsive nowrap w-100">
	<thead class="table-light">
		<tr>
			<th title="Agent Name"><img class="action-image" src="~/headers/customer.gif" /></th>
			<th>
				<i class="far fa-user text-primary" title="This Image has agent photo at the location" data-toggle="tooltip"></i>
			</th>
			<th title="Verified Address"><img class="action-image" src="~/headers/pincode.gif" /></th>
			<th>Verified Address</th>
			<th title="More info"><img class="action-image" src="~/headers/information.gif" /></th>
			<th>Match</th>
			<th title="Action"><img class="action-image" src="~/headers/action.gif" /></th>
		</tr>
	</thead>
	<tbody>
		<tr>
			<td>
					<small>
				@if (agent!.ValidationExecuted)
				{
					@location.AgentEmail
				}
				else
				{
					<small>@agent.ReportType.GetEnumDisplayName()</small>
				}
				@if (agent.IsRequired)
				{
					<span class="required-asterisk" title="Mandatory Location">*</span>
				}
					</small>
			</td>
				<td class="text-center face-photo-column">
					@if (agent.FaceResult != null && agent.FaceResult.TotalFacesDetected > 0)
					{
						<div class="badge bg-info text-white bottom-0 end-0 m-2 opacity-90">
							<i class="fas fa-user-check"></i> AI Verified
						</div>
					}
					@if (agent.ValidationExecuted)
					{
						<div class="position-relative d-inline-block mb-2 face-image-wrapper">
							<img id="face-img-@agent.Id"
								 src="/Document/GetAgentDocument/@agent.Id"
								 class="mobile-capture-info img-thumbnail img-fluid shadow-sm"
								 title="@location.AgentEmail photo" />
						</div>

						@if (agent.FaceResult != null)
						{
							<div class="text-start mt-1 p-2 bg-white rounded border face-metrics-box text-left">
								@if (agent.FaceResult.TotalFacesDetected == 0)
								{
									<div class="text-danger text-center fw-bold small">
										<i class="fas fa-exclamation-triangle"></i> No face detected
									</div>
								}
								else
								{
									@foreach (var face in agent.FaceResult.Faces)
									{
										<div class="card border-0 shadow-sm mb-3 @(face.FaceNumber > 1 ? "border-top pt-3" : "")">
											<div class="card-body p-2">
												<!-- Header -->
												<span class="d-flex align-items-center text-primary fw-bold small mb-2">
													<i class="fas fa-robot"></i> 
													<span class="badge fw-semibold small">
													Face Detail #@face.FaceNumber
													</span>
												</span>

												<!-- Metrics Table/Grid -->
												<div class="d-flex flex-column gap-2 p-0 mb-2">
													<!-- Age Range -->
													<div class="p-2 rounded border d-flex align-items-center justify-content-between bg-light border-secondary-subtle">
														<div class="d-flex align-items-center text-muted">
															<i class="fas fa-hourglass-half fs-6 me-2"></i>
															<span class="badge fw-semibold small">Age Range</span>
														</div>
														<span class="fw-bold small text-dark">@face.AgeRange</span>
													</div>

													<!-- Gender -->
													<div class="p-2 rounded border d-flex align-items-center justify-content-between bg-light border-secondary-subtle">
														<div class="d-flex align-items-center text-muted">
															<i class="fas @(face.Gender?.ToLower() == "female" ? "fa-venus" : face.Gender?.ToLower() == "male" ? "fa-mars" : "fa-genderless") fs-6 me-2"></i>
															<span class="badge fw-semibold small">Gender</span>
														</div>
														<div class="d-flex align-items-center gap-1">
															<span class="fw-bold small text-dark">@face.Gender</span>
															<span class="badge bg-white text-secondary border fw-normal text-xs">@face.GenderConfidence.ToString("F0")%</span>
														</div>
													</div>

													<!-- Primary Emotion -->
													<div class="p-2 rounded border d-flex align-items-center justify-content-between bg-light border-secondary-subtle">
														<div class="d-flex align-items-center text-muted">
															<i class="fas fa-heart fs-6 me-2"></i>
															<span class="badge fw-semibold small">Emotion</span>
														</div>
														<span class="fw-bold small text-dark text-capitalize">@face.PrimaryEmotion</span>
													</div>
												</div>

												<!-- Features Badges Grid -->
												<div class="d-flex flex-column gap-2 pt-1 mt-2">
													<!-- Smile -->
													<div class="p-2 rounded border d-flex align-items-center justify-content-between @(face.IsSmiling ? "bg-success-subtle text-success border-success" : "bg-light text-muted border-secondary-subtle")">
														<div class="d-flex align-items-center">
															<i class="fas @(face.IsSmiling ? "fa-smile" : "fa-meh") fs-5 me-2"></i> <span class="badge  fw-semibold small"> Smile </span>
														</div>
														<span class="fs-5 fw-bold @(face.IsSmiling ? "text-success" : "text-danger")">
															@(face.IsSmiling ? "✓" : "✗")
														</span>
													</div>

													<!-- Glasses -->
													<div class="p-2 rounded border d-flex align-items-center justify-content-between @(face.IsWearingGlasses ? "bg-info-subtle text-info-emphasis border-info" : "bg-light text-muted border-secondary-subtle")">
														<div class="d-flex align-items-center">
															<i class="fas fa-glasses fs-5 me-2"></i> <span class="badge fw-semibold small"> Glasses </span>
															 
														</div>
														<span class="fs-5 fw-bold @(face.IsWearingGlasses ? "text-success" : "text-danger")">
															@(face.IsWearingGlasses ? "✓" : "✗")
														</span>
													</div>

													<!-- Beard -->
													<div class="p-2 rounded border d-flex align-items-center justify-content-between @(face.HasBeard ? "bg-warning-subtle text-warning-emphasis border-success" : "bg-light text-muted border-secondary-subtle")">
														<div class="d-flex align-items-center">
															<i class="fas fa-user-tie fs-5 me-2"></i> <span class="badge fw-semibold small"> Beard </span>
															 
														</div>
														<span class="fs-5 fw-bold @(face.HasBeard ? "text-success" : "text-danger")">
															@(face.HasBeard ? "✓" : "✗")
														</span>
													</div>
												</div>
											</div>
										</div>
									}
								}
								
							</div>
						}
					}
					else
					{
						<img src="~/img/no-user.png" class="img-thumbnail img-fluid profile-image" />
					}
				</td>
			<td>
				@if (agent.ValidationExecuted && agent.LocationMapUrl != null)
				{
					<img src="@string.Format(@agent.LocationMapUrl, "400","400")"
						 class="thumbnail-image thumbnail profile-image doc-profile-image map-image"
						 data-faceid="@agent.Id"
						 data-locationid="@location.Id"
						 data-source="agent"
						 title="Click to view map" />
				}
				else
				{
					<img src="~/img/no-map.jpeg" class="thumbnail profile-image doc-profile-image" />
				}
			</td>
			<td>
				@agent.LocationAddress

			</td>
			<td>
				@agent.LocationInfo

			</td>
			<td>
				@if (agent.ValidationExecuted)
				{
					@if (agent.ImageValid.GetValueOrDefault())
					{
						<i class='fas fa-check-circle i-green'></i>
					}
					else
					{
						<i class='fa fa-times i-orangered' aria-hidden='true'></i>
					}
				}
				else
				{
					<i class='fa fa-times i-grey' aria-hidden='true'></i>
				}
				@agent.Similarity
			</td>
			<td>
				<input type="file" class="form-control remarks document-image-input face-upload" data-faceid="@agent.Id" accept="image/*"
					   data-toggle="tooltip" title="Agent Photo" />
				<button type="button" class="btn btn-sm btn-success mt-2 upload-face-btn"
						data-faceid="@agent.Id"
						data-isagent="true"
						data-location-name="@location.LocationName"
						data-locationid="@location.Id"
						data-name="@agent.ReportName">
					<i class="fas fa-upload"></i> Upload
				</button>
				<div id="upload-status-@agent.Id" class="text-success small mt-1"></div>
			</td>

		</tr>
	</tbody>
</table>
</div>