@model risk.control.system.Models.Vendor

@{
	ViewData["Title"] = @Applicationsettings.EDIT;
}
<section class="content">
	<form id="edit-form" asp-action="Edit" enctype="multipart/form-data">
		<div class="card shadow-lg border-1 rounded-lg">
			<div class="card-header bg-secondary text-white text-center">
				<h3 class="card-title"><i class="fas fa-building"></i> @Applicationsettings.EDIT Agency  </h3>
			</div>

			<div class="card-body">
				<div asp-validation-summary="ModelOnly" class="text-danger"></div>
				<input type="hidden" name="vendorId" asp-for="VendorId" />
				<input type="hidden" asp-for="AddressLatitude" />
				<input type="hidden" asp-for="AddressLongitude" />
				<input type="hidden" asp-for="AddressMapLocation" />
				<input type="hidden" asp-for="MobileAppUrl" />
				<div class="submit-progress hidden">
					<i class="fas fa-sync fa-spin fa-4x fa-fw"></i>
				</div>
				<partial name="Vendor/_Edit" model="Model" />
			</div>
			<div class="card-footer">
				<div class="row">
					<div class="col-md-12">
						<div class="form-group text-right">
							<a id="cancel" asp-controller="Agency" asp-action="Index" class="btn btn-secondary">
								<i class="fa fa-window-close"></i>
								Cancel
							</a>
							<button id="edit" type="submit" class="btn btn-warning">
								<i class="fas fa-building"></i>  Save Agency
							</button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</form>
</section>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
	<script src="~/js/company-admin/edit-agency.js"> </script>
	<script src="~/js/common/address-with-pincode.js"></script>
	<script src="~/js/company-admin/phone-bank-validate.js"></script>
	<script src="~/js/common/logo-upload.js"></script>
	<script src="~/js/common/form-validation.js"></script>
}